# AgencyOS环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=agencyadmin
DB_PASSWORD=123456
DB_NAME=agencyos_db

# 安全配置
# JWT加密密钥，至少32字节(256位)
# 使用如下命令生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-super-secret-jwt-signing-key-here

# LLM提供商API密钥
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
DIFY_API_KEY=
OPENCLAW_API_KEY=

# Dify配置
DIFY_API_BASE=http://localhost:8765/v1
DIFY_APP_ID=

# OpenClaw配置
OPENCLAW_API_BASE=http://localhost:8080/v1
OPENCLAW_APP_ID=

# 邮件配置
MAIL_SMTP_SERVER=
MAIL_SMTP_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=